<%- include('includes/head') %>
    <%- include('includes/nav') %>

        <div class="container">
            <div class="row">
                <div class="col-lg-2"></div>

                <div class="col-lg-8 my-3">
                    <h1 class="text-center">Agenda</h1>
                    <p class="text-center lead">Crie ou edite seus contatos por aqui.</p>

                    <%- include('includes/messages'); %>
                    <div class="errors-container"></div>
                        <% if(contato._id) { %>
                            <form  class="form-contato" action="/contatos/edit/<%= contato._id %>" method="POST">
                                <% %>
                                    <% } else { %>
                                        <form  class="form-contato" action="/contatos/register" method="POST">
                                            <% } %>
                                                <div class="form-group">
                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                    <label>Nome:</label>
                                                    <input value="<%= contato.nome %>" type="text"
                                                        class="form-control form-control-lg" name="nome"
                                                        placeholder="Seu nome aqui...">
                                                </div>
                                                <div class="form-group">

                                                    <label>Sobrenome:</label>
                                                    <input value="<%= contato.sobrenome %>" type="text"
                                                        class="form-control form-control-lg" name="sobrenome"
                                                        placeholder="Seu sobrenome aqui...">
                                                </div>
                                                <div class="form-group">

                                                    <label>Email:</label>
                                                    <input value="<%= contato.email %>" type="email"
                                                        class="form-control form-control-lg" name="email"
                                                        placeholder="exemplo@email.com">
                                                </div>
                                                <div class="form-group">

                                                    <label>Telefone:</label>
                                                    <input value="<%= contato.telefone %>" type="tel"
                                                        class="form-control form-control-lg" name="telefone"
                                                        placeholder="Seu telefone aqui...">
                                                </div>

                                                <button type="submit" class="btn btn-success btn-block">Salvar</button>
                                        </form>

                </div>

                <div class="col-lg-2"></div>
            </div>
        </div>

        <%- include('includes/footer') %>