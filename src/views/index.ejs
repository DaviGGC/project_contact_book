<%- include('includes/head') %>
  <%- include('includes/nav') %>

    <div class="container">
      <div class="row">
        <div class="col-lg-2"></div>

        <div class="col-lg-8 my-3">
          <h1 class="text-center">Agenda</h1>
          <p class="text-center lead">Seus contatos estão abaixo:</p>

          <%- include('includes/messages'); %>

            <% if (contatos.length> 0) { %>
              <table class="table table-hover table-striped my-3" style="table-layout: auto; width: 100%;">
                <thead>
                  <tr>
                    <th>Nome</th>
                    <th>Sobrenome</th>
                    <th>Telefone</th>
                    <th>E-mail</th>
                    <th></th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  <% contatos.forEach(contato=> { %>
                    <tr>
                      <td class="text-truncate" style="max-width: 150px;">
                        <%= contato.nome %>
                      </td>
                      <td>
                        <%= contato.sobrenome %>
                      </td>
                      <td>
                        <%= contato.telefone %>
                      </td>
                      <td style="word-break: break-all; max-width: 200px;">
                        <%= contato.email %>
                      </td>
                      <td><a href="/contatos/index/<%= contato._id %>">Editar</a></td>
                      <td><a href="/contatos/delete/<%= contato._id %>" class="text-danger">Excluir</a></td>
                    </tr>
                    <% }); %>
                </tbody>
              </table>
              <% } else { %>
                <p class="text-center lead">Não existem contatos na sua agenda.</p>
                <% } %>
        </div>
        <div class="col-lg-2"></div>
      </div>
    </div> <%- include('includes/footer') %>